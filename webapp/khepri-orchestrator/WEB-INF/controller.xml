<?xml version="1.0" encoding="UTF-8"?>
<site-conf xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns="http://ofbiz.apache.org/Site-Conf" xsi:schemaLocation="http://ofbiz.apache.org/Site-Conf http://ofbiz.apache.org/dtds/site-conf.xsd">

    <include location="component://common/webcommon/WEB-INF/common-controller.xml"/>

    <description>Khepri-orchestrator Component Site Configuration File</description>

    <request-map uri="main">
        <security https="true" auth="true"/>
        <response name="success" type="view" value="main"/>
    </request-map>

    <request-map uri="vueApp">
        <security https="true" auth="true"/>
        <response name="success" type="view" value="VueAppView"/>
    </request-map>

    <request-map uri="static">
        <security https="false" auth="false"/>
        <response name="success" type="none"/>
    </request-map>

    <view-map name="main" type="screen" page="component://khepri-orchestrator/widget/Khepri-orchestratorScreens.xml#main"/>

    <view-map name="VueAppView" type="screen" page="component://khepri-orchestrator/widget/Khepri-orchestratorScreens.xml#VueAppScreen"/>

</site-conf>