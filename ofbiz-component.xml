<?xml version="1.0" encoding="UTF-8"?>
<ofbiz-component name="khepri-orchestrator"
                 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xsi:noNamespaceSchemaLocation="https://ofbiz.apache.org/dtds/ofbiz-component.xsd">
    <resource-loader name="main" type="component"/>
    <classpath type="dir" location="config"/>

    <!-- Classpath para classes compiladas (Java e Groovy) -->
    <classpath type="dir" location="build/classes/java/main"/>
    <classpath type="dir" location="build/classes/groovy/main"/>

    <!-- Recursos de Entidade -->
    <entity-resource type="model" reader-name="main" loader="main" location="entitydef/entitymodel.xml"/>
    <entity-resource type="data" reader-name="seed" loader="main" location="data/Khepri-orchestratorTypeData.xml"/>
    <entity-resource type="data" reader-name="seed" loader="main" location="data/Khepri-orchestratorSecurityPermissionSeedData.xml"/>
    <entity-resource type="data" reader-name="demo" loader="main" location="data/Khepri-orchestratorSecurityGroupDemoData.xml"/>
    <entity-resource type="data" reader-name="demo" loader="main" location="data/Khepri-orchestratorDemoData.xml"/>

    <!-- Recursos de Serviço -->
    <service-resource type="model" loader="main" location="servicedef/services.xml"/>
    <service-resource type="model" loader="main" location="servicedef/services_bff.xml"/>
    <service-resource type="model" loader="main" location="servicedef/services_core.xml"/>

    <!-- Suíte de Testes -->
    <test-suite loader="main" location="testdef/Khepri-orchestratorTests.xml"/>

    <!-- Web Application -->
    <webapp name="khepri-orchestrator"
            title="Khepri-orchestrator"
            server="default-server"
            location="webapp/khepri-orchestrator"
            base-permission="OFBTOOLS"
            mount-point="/khepri-orchestrator"/>
</ofbiz-component>